.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 30rpx;
}

.form-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.input, .picker {
  background: #f5f5f5;
  padding: 25rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.picker {
  color: #999;
}

.textarea {
  background: #f5f5f5;
  padding: 25rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  height: 180rpx;
  width: 100%;
  box-sizing: border-box;
}

.submit-btn {
  background: linear-gradient(135deg, #2196F3, #1976D2);
  color: white;
  border-radius: 60rpx;
  margin-top: 50rpx;
  font-size: 34rpx;
  font-weight: normal;
}