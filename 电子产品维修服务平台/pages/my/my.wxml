<view class="container">
  <!-- 头部信息 -->
  <view class="header">
    <view class="avatar">👤</view>
    <view class="info">
      <text class="name">维修用户</text>
      <text class="phone">{{phoneNumber || '未绑定手机'}}</text>
    </view>
  </view>

  <!-- 订单统计 -->
  <view class="stats">
    <view class="stats-item">
      <text class="num">{{orders.length}}</text>
      <text class="label">总订单</text>
    </view>
    <view class="stats-item">
      <text class="num">{{pendingCount}}</text>
      <text class="label">待处理</text>
    </view>
    <view class="stats-item">
      <text class="num">{{completedCount}}</text>
      <text class="label">已完成</text>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="section-title">我的预约</view>
  
  <view class="order-list">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="order-card">
        <view class="order-header">
          <text class="service">{{item.service}}</text>
          <text class="status {{item.status}}">
            {{item.status === 'pending' ? '待处理' : 
              item.status === 'processing' ? '处理中' : '已完成'}}
          </text>
        </view>
        <view class="order-info">
          <text>📱 {{item.model}}</text>
          <text>📅 {{item.date}}</text>
          <text>👤 {{item.name}}</text>
          <text>📞 {{item.phone}}</text>
        </view>
        <view class="order-desc">{{item.desc}}</view>
        <view class="order-footer">
          <text class="time">{{item.createTime}}</text>
          <text class="delete" bindtap="deleteOrder" data-id="{{item.id}}">删除</text>
        </view>
      </view>
    </block>

    <view wx:if="{{orders.length === 0}}" class="empty">
      暂无预约记录，去首页预约吧~
    </view>
  </view>
</view>