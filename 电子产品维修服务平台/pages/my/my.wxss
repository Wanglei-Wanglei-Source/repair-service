.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 30rpx;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #2196F3, #1976D2);
  padding: 50rpx 30rpx;
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-right: 30rpx;
}

.info .name {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  display: block;
}

.info .phone {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 10rpx;
  display: block;
}

/* 统计 */
.stats {
  display: flex;
  background: white;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-item .num {
  font-size: 44rpx;
  font-weight: bold;
  color: #2196F3;
  display: block;
}

.stats-item .label {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

/* 订单列表 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  padding: 20rpx 30rpx;
}

.order-list {
  padding: 0 20rpx;
}

.order-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.service {
  font-size: 32rpx;
  font-weight: bold;
}

.status {
  font-size: 26rpx;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
}

.status.pending {
  background: #FFF3E0;
  color: #FF9800;
}

.status.processing {
  background: #E3F2FD;
  color: #2196F3;
}

.status.completed {
  background: #E8F5E9;
  color: #4CAF50;
}

.order-info {
  margin-bottom: 20rpx;
}

.order-info text {
  display: inline-block;
  margin-right: 25rpx;
  margin-bottom: 15rpx;
  font-size: 26rpx;
  color: #666;
}

.order-desc {
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.delete {
  color: #F44336;
}

.empty {
  text-align: center;
  padding: 150rpx 0;
  color: #999;
  font-size: 28rpx;
}